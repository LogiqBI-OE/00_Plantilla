# Copia este archivo a .env y ajusta valores para tu entorno local.
# NUNCA commitear .env (esta cubierto por .gitignore).

# Django
DJANGO_SECRET_KEY=change-me-in-production-this-is-only-for-local-dev
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres)
DATABASE_URL=postgres://plantilla:plantilla@localhost:5432/plantilla

# Redis (Celery broker + backend)
REDIS_URL=redis://localhost:6379/0

# CORS (frontend dev origin)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT lifetimes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
